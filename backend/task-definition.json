{
  "family": "vaidya-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "vaidya-backend",
      "image": "ACCOUNT_ID.dkr.ecr.ap-south-2.amazonaws.com/vaidya-backend:latest",
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {"name": "DATABASE_URL",       "value": "REPLACE_WITH_YOUR_DATABASE_URL"},
        {"name": "GEMINI_API_KEY",     "value": "REPLACE_WITH_YOUR_GEMINI_API_KEY"},
        {"name": "GEMINI_MODEL",       "value": "gemini-2.0-flash"},
        {"name": "SECRET_KEY",         "value": "REPLACE_WITH_A_RANDOM_SECRET_KEY"},
        {"name": "TWILIO_ACCOUNT_SID", "value": "REPLACE_WITH_YOUR_TWILIO_ACCOUNT_SID"},
        {"name": "TWILIO_AUTH_TOKEN",  "value": "REPLACE_WITH_YOUR_TWILIO_AUTH_TOKEN"},
        {"name": "TWILIO_FROM_NUMBER", "value": "REPLACE_WITH_YOUR_TWILIO_PHONE_NUMBER"},
        {"name": "FCM_PROJECT_ID",     "value": "REPLACE_WITH_YOUR_FCM_PROJECT_ID"},
        {"name": "ENV",                "value": "production"},
        {"name": "REDIS_URL",          "value": "REPLACE_WITH_YOUR_REDIS_URL"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/vaidya-backend",
          "awslogs-region": "ap-south-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
