{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Vaidya Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Vaidya AI Triage — Ops Dashboard. Covers: request latency, model inference time, triage volume by district, error rates, ASHA notification delivery, active sessions.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "Active Triage Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "vaidya_active_triage_sessions",
        "legendFormat": "Active sessions",
        "refId": "A"
      }]
    },

    {
      "id": 2,
      "title": "Request Rate (req/min)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqpm", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 300 },
            { "color": "red", "value": 500 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(http_requests_total[1m]) * 60",
        "legendFormat": "req/min",
        "refId": "A"
      }]
    },

    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 1.0 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m]) * 100",
        "legendFormat": "5xx error rate",
        "refId": "A"
      }]
    },

    {
      "id": 4,
      "title": "LLM Fallback Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 30 },
            { "color": "red", "value": 50 }
          ]},
          "description": "High values indicate XGBoost is underperforming — consider retraining"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(vaidya_llm_fallback_total[5m]) / rate(vaidya_triage_total[5m]) * 100",
        "legendFormat": "LLM fallback %",
        "refId": "A"
      }]
    },

    {
      "id": 5,
      "title": "API Request Latency — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 6,
      "title": "Model Inference Time — p95 by Model Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(vaidya_model_inference_seconds_bucket{model=\"nlp\"}[5m])) * 1000",
          "legendFormat": "NLP (XGBoost)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(vaidya_model_inference_seconds_bucket{model=\"llm_fallback\"}[5m])) * 1000",
          "legendFormat": "LLM Fallback (Ollama)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(vaidya_model_inference_seconds_bucket{model=\"audio\"}[5m])) * 1000",
          "legendFormat": "Audio",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(vaidya_model_inference_seconds_bucket{model=\"vision\"}[5m])) * 1000",
          "legendFormat": "Vision",
          "refId": "D"
        }
      ]
    },

    {
      "id": 7,
      "title": "Triage Volume by District",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "barWidth": 0.7, "groupWidth": 0.7, "orientation": "horizontal" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (district) (increase(vaidya_triage_total[24h]))",
        "legendFormat": "{{district}}",
        "refId": "A"
      }]
    },

    {
      "id": 8,
      "title": "Triage Severity Distribution (last 24h)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "barWidth": 0.8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (severity) (increase(vaidya_triage_total[24h]))",
        "legendFormat": "{{severity}}",
        "refId": "A"
      }]
    },

    {
      "id": 9,
      "title": "ASHA Notification Delivery",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(vaidya_asha_notification_total{status=\"sent\"}[5m])",
          "legendFormat": "{{channel}} sent",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(vaidya_asha_notification_total{status=\"failed\"}[5m])",
          "legendFormat": "{{channel}} failed",
          "refId": "B"
        }
      ]
    },

    {
      "id": 10,
      "title": "External API Latency — p95",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.95, rate(vaidya_external_api_seconds_bucket[5m])) * 1000",
        "legendFormat": "{{service}}",
        "refId": "A"
      }]
    },

    {
      "id": 11,
      "title": "Outbreak Alerts (last 7 days)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "increase(vaidya_outbreak_alerts_total[7d])",
        "legendFormat": "{{disease}} / {{district}}",
        "refId": "A"
      }]
    },

    {
      "id": 12,
      "title": "DPDP Consent Grants (last 24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "increase(vaidya_consent_total{action=\"grant\"}[24h])",
        "legendFormat": "{{type}}",
        "refId": "A"
      }]
    },

    {
      "id": 13,
      "title": "Offline vs Online Inference Ratio",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 26 },
      "fieldConfig": {
        "defaults": { "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 20 },
            { "color": "red", "value": 40 }
          ]},
          "description": "High offline % indicates poor connectivity in field — consider model size reduction"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(vaidya_offline_inference_total{result=\"success\"}[1h]) / (rate(vaidya_triage_total[1h]) + 0.001) * 100",
        "legendFormat": "offline %",
        "refId": "A"
      }]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["vaidya", "medical", "triage", "pilot"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Kolkata",
  "title": "Vaidya — Ops Dashboard",
  "uid": "vaidya-ops-v1",
  "version": 1,
  "weekStart": "monday"
}
