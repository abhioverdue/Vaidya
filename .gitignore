# ── ML model artifacts (large binary files) ──────────────────────────────────
*.pkl
*.pth
*.h5
# Keep trained model files for mobile offline inference
# (ONNX / TFLite are binary but must be in git for EAS Build to bundle them)
!frontend/src/assets/models/*.onnx
!frontend/src/assets/models/*.tflite
# Exclude large training-side model checkpoints only
backend/**/*.onnx
backend/**/*.tflite
models/**/*.onnx
models/**/*.tflite

